<!DOCTYPE html>
<html lang="ro">
<head>
<meta charset="UTF-8">
<title>Conversia din baza 10 în baza 2</title>

<style>
    table {
        border-collapse: collapse;
        border: 3px solid cornflowerblue;
        background-color: #1e3a8a;
    }
    th, td {
        border: 3px solid cornflowerblue;
        padding: 8px;
        text-align: center;
        color:aliceblue;
    }

    .container {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
    }

    .dreapta {
        margin-left: 30px;
    }

    .centru {
        display: flex;
        align-items: center;
        justify-content: center;
        flex: 1;
        font-size: 32px;
        font-weight: bold;
        margin: 0 30px;
        min-height: 200px;
    }

    .digit {
        opacity: 0;
        display: inline-block;
        animation: fadeIn 0.7s forwards;
    }

    @keyframes fadeIn { 
        from { opacity: 0; transform: translateY(10px); } /* animatie pentru 97 in baza 2 */
        to { opacity: 1; transform: translateY(0); }
    }

    .d1 { animation-delay: 0s; } /* fiecare cifră va apărea cu o întârziere de 0.7s față de cea anterioară */
    .d2 { animation-delay: 0.7s; }
    .d3 { animation-delay: 1.4s; }
    .d4 { animation-delay: 2.1s; }
    .d5 { animation-delay: 2.8s; }
    .d6 { animation-delay: 3.5s; }
    .d7 { animation-delay: 4.2s; }
    .d8 { animation-delay: 4.9s; }

    body{
        background-color: azure;
    }

</style>
</head>

<body>

<h2>Conversia din baza 10 în baza 2</h2>

<div class="container">
    
    <div>
        <h3>Pasul I</h3>
        <table>
            <tr>
                <th>Pas</th>
                <th>Număr de împărțit</th>
                <th>Cât</th>
                <th>Rest</th>
            </tr>
            <tr><td>1</td><td>97</td><td>48</td><td>1</td></tr>
            <tr><td>2</td><td>48</td><td>24</td><td>0</td></tr>
            <tr><td>3</td><td>24</td><td>12</td><td>0</td></tr>
            <tr><td>4</td><td>12</td><td>6</td><td>0</td></tr>
            <tr><td>5</td><td>6</td><td>3</td><td>0</td></tr>
            <tr><td>6</td><td>3</td><td>1</td><td>1</td></tr>
            <tr><td>7</td><td>1</td><td>0</td><td>1</td></tr>
        </table>
    </div>

    <div class="centru">
        <span class="digit d1">1</span> <!--cifrele pentru formarea a numarului 97 in baza 2 -->
        <span class="digit d2">1</span> 
        <span class="digit d3">0</span>
        <span class="digit d4">0</span>
        <span class="digit d5">0</span>
        <span class="digit d6">0</span>
        <span class="digit d7">1</span>
        <span class="digit d8" style="margin-left:10px;">₂</span>
    </div>

    <div class="dreapta">
        <h3>Pasul II</h3>
        <p style="font-size: 30px;">Citim resturile de jos în sus → <strong>1100001₂</strong></p>
    </div>

</div>

</body>
</html>